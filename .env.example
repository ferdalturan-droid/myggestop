# ---------------------------------------------------------------------------
# Myggestop – miljovariabler. Kopier til .env og udfyld.
# ---------------------------------------------------------------------------

# PostgreSQL forbindelse (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/myggestop?schema=public"

# Offentlig URL til sitet (bruges til SEO, canonical, sitemap, PDF-links)
NEXT_PUBLIC_SITE_URL="https://www.myggestop.dk"

# Hemmelig nogle til admin-session (skift til en lang tilfaeldig streng)
AUTH_SECRET="skift-denne-til-en-meget-lang-tilfaeldig-streng-min-32-tegn"

# Standard admin-login (oprettes ved seed). Kan aendres i admin-panelet.
ADMIN_EMAIL="ferdalturan@gmail.com"
ADMIN_PASSWORD="MyggeStop2026!"

# SMTP til udsendelse af ordre-emails (f.eks. Gmail App Password, SendGrid, Mailgun)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="ferdalturan@gmail.com"
SMTP_PASS="dit-app-password"
SMTP_FROM="Myggestop <ferdalturan@gmail.com>"
